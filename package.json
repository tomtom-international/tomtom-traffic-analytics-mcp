{
  "name": "@tomtom-org/tomtom-traffic-analytics-mcp",
  "version": "0.2.0",
  "description": "MCP server for TomTom traffic analytics — junctions, routes, incidents, and area analysis",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    "import": "./dist/index.esm.js",
    "require": "./dist/index.cjs.js"
  },
  "bin": {
    "tomtom-traffic-analytics-mcp": "./bin/tomtom-traffic-analytics-mcp.js",
    "tomtom-traffic-analytics-mcp-http": "./bin/tomtom-traffic-analytics-mcp-http.js"
  },
  "scripts": {
    "build:ts": "tsc --emitDeclarationOnly --declaration --declarationMap",
    "build:rollup": "rollup -c",
    "build": "npm run build:ts && npm run build:rollup",
    "build:bin": "shx chmod +x bin/tomtom-traffic-analytics-mcp.js bin/tomtom-traffic-analytics-mcp-http.js",
    "start": "node dist/index.js",
    "start:http": "node dist/indexHttp.esm.js",
    "dev": "npx tsx src/index.ts",
    "dev:http": "npx tsx src/indexHttp.ts",
    "prepare": "npm run build",
    "test": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:comprehensive": "node tests/test-comprehensive.js",
    "test:http": "node tests/test-http-tools.js",
    "test:all": "npm run test && npm run test:comprehensive && npm run test:http",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:report": "eslint src --format json --output-file eslint-report.json",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "inspector": "node run-inspector.js",
    "build:mcpb": "node scripts/build-mcpb.cjs",
    "version:sync": "node scripts/generate-version.cjs",
    "publish:npm": "npm publish --access public",
    "clean": "shx rm -rf dist coverage eslint-report.json",
    "prebuild": "npm run clean"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.2-r.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.0",
    "node-fetch": "^3.3.2",
    "tslib": "^2.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "latest",
    "@eslint/config-array": "^0.21.0",
    "@eslint/object-schema": "^2.1.6",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.6.0",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "archiver": "^7.0.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "prettier": "^3.6.1",
    "rollup": "^4.44.1",
    "rollup-plugin-license": "^3.7.1",
    "shx": "^0.4.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.9.5"
  },
  "engines": {
    "node": ">=22.9.0"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "keywords": [
    "tomtom",
    "mcp",
    "traffic",
    "maps",
    "analytics",
    "cross-platform"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomtom-international/tomtom-traffic-analytics-mcp.git"
  },
  "homepage": "https://github.com/tomtom-international/tomtom-traffic-analytics-mcp#readme",
  "bugs": {
    "url": "https://github.com/tomtom-international/tomtom-traffic-analytics-mcp/issues"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md",
    "manifest.json"
  ],
  "overrides": {
    "inflight": "npm:lru-cache@^11.1.0",
    "tmp": "^0.2.4"
  }
}
