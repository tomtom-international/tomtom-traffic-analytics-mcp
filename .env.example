# TomTom MOVE Portal API key - required for all traffic analytics tools
# Get your key from https://move.tomtom.com/
TOMTOM_MOVE_PORTAL_KEY=your_move_portal_key_here

# TomTom Developer API key - required for live traffic tools (flow, incidents)
# Get your key from https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_api_key_here

# Port for the HTTP server (default: 3000)
PORT=3000

# CORS allowed origins for HTTP server (comma-separated, default: * for all origins)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.com

# Logging level (default: info)
# LOG_LEVEL=info

# Node environment (development or production)
NODE_ENV=production
